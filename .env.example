# Smart Scheduler — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# Groq API (LLM + Whisper STT + Orpheus TTS)
# Get yours free at: https://console.groq.com
GROQ_API_KEY=

# Google OAuth2 Credentials
# Create a project at: https://console.cloud.google.com
# Enable: Google Calendar API
# Create OAuth 2.0 Client ID (Web Application type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Session secret — any long random string, e.g. run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
